<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.memorymatch">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MemoryMatch">

        <!-- ── Lobby (launcher) ─────────────────────────────────────────── -->
        <activity
            android:name=".ui.lobby.LobbyActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Login screen ────────────────────────────────────────────── -->
        <activity
            android:name=".ui.lobby.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.lobby.LobbyActivity" />

        <!-- ── Leaderboard screen ───────────────────────────────────────── -->
        <activity
            android:name=".ui.lobby.LeaderboardActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.lobby.LobbyActivity" />

        <!-- ── Game screen ──────────────────────────────────────────────── -->
        <activity
            android:name=".ui.game.GameActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.lobby.LobbyActivity" />

    </application>

</manifest>
